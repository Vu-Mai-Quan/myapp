{
  "extends": [
    "development"
  ],
  "hints": {
    "typescript-config/consistent-casing": "off",
    "axe/name-role-value": [
      "default",
      {
        "link-name": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not chrome <= 109",
    "not firefox <= 115",
    "not ios_saf <= 16.7",
    "not ios_saf <= 17.4",
    "not safari <= 17.4"
  ]
}